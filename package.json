{
  "name": "merkle-tree-poseidon-sdk",
  "version": "1.0.1",
  "author": "ardial@hara.ag",
  "description": "TypeScript SDK for Merkle Tree and Poseidon Selective Disclosure",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "npm run test:sdk && npm run test:tree",
